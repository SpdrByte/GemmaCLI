{
  "esp32c3_supermini": {
    "label": "ESP32-C3 SuperMini",
    "vendor": "Espressif Systems",
    "architecture": "RISC-V",
    "default_vcc": 3.3,
    "notes": "Compact form factor. GPIO8/9 are default I2C. GPIO20/21 are UART0 (USB). Strapping pins: GPIO2, GPIO8, GPIO9.",
    "layout": {
      "left":  ["GPIO0", "GPIO1", "GPIO2", "GPIO3", "GPIO4", "GPIO5", "GND", "3V3"],
      "right": ["5V", "GND", "3V3", "GPIO10", "GPIO9", "GPIO8", "GPIO21", "GPIO20"]
    },
    "pins": {
      "GPIO0":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH0"] },
      "GPIO1":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH1"] },
      "GPIO2":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH2"], "notes": "Strapping pin — avoid pulling low at boot" },
      "GPIO3":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH3"] },
      "GPIO4":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH4", "SPI_CS"] },
      "GPIO5":  { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_MISO"] },
      "GPIO6":  { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_SCK"] },
      "GPIO7":  { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_MOSI"] },
      "GPIO8":  { "type": "IO",        "voltage": 3.3, "protocols": ["I2C_SDA"], "notes": "Default I2C SDA. Strapping pin." },
      "GPIO9":  { "type": "IO",        "voltage": 3.3, "protocols": ["I2C_SCL"], "notes": "Default I2C SCL. Strapping pin — internal pull-up at boot." },
      "GPIO10": { "type": "IO",        "voltage": 3.3, "protocols": [] },
      "GPIO20": { "type": "IO",        "voltage": 3.3, "protocols": ["UART_RX"], "notes": "UART0 RX — used for USB serial" },
      "GPIO21": { "type": "IO",        "voltage": 3.3, "protocols": ["UART_TX"], "notes": "UART0 TX — used for USB serial" },
      "3V3":    { "type": "POWER_OUT", "voltage": 3.3, "protocols": [] },
      "5V":     { "type": "POWER_IN",  "voltage": 5.0, "protocols": [] },
      "GND":    { "type": "GROUND",    "voltage": 0,   "protocols": [] }
    }
  },

  "esp32_devkit": {
    "label": "ESP32 DevKit V1",
    "vendor": "Espressif Systems",
    "architecture": "Xtensa LX6 dual-core",
    "default_vcc": 3.3,
    "notes": "Classic ESP32. 38-pin variant. GPIO6-11 connected to internal flash — do not use.",
    "layout": {
      "left":  ["3V3", "GND", "GPIO15", "GPIO2",  "GPIO0",  "GPIO4",  "GPIO16", "GPIO17", "GPIO5",  "GPIO18", "GPIO19", "GND",    "GPIO21", "GPIO3",  "GPIO1",  "GPIO22", "GPIO23", "GND"],
      "right": ["VIN", "GND", "GPIO13", "GPIO12", "GPIO14", "GPIO27", "GPIO26", "GPIO25", "GPIO33", "GPIO32", "GPIO35", "GPIO34", "GPIO39", "GPIO36", "EN",     "GND",    "GPIO23", "5V"]
    },
    "pins": {
      "GPIO0":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH1"],                        "notes": "Strapping pin — must be HIGH at boot for normal mode" },
      "GPIO1":  { "type": "IO",        "voltage": 3.3, "protocols": ["UART_TX"],                         "notes": "UART0 TX" },
      "GPIO2":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH2", "TOUCH2"],              "notes": "Strapping pin — must be LOW or floating at boot" },
      "GPIO3":  { "type": "IO",        "voltage": 3.3, "protocols": ["UART_RX"],                         "notes": "UART0 RX" },
      "GPIO4":  { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH0", "TOUCH0"] },
      "GPIO5":  { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_CS"],                          "notes": "Strapping pin" },
      "GPIO12": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH5", "TOUCH5", "SPI_MISO"], "notes": "Strapping pin — must be LOW at boot" },
      "GPIO13": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH4", "TOUCH4", "SPI_MOSI"] },
      "GPIO14": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH6", "TOUCH6", "SPI_SCK"] },
      "GPIO15": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH3", "TOUCH3", "SPI_CS"],   "notes": "Strapping pin" },
      "GPIO16": { "type": "IO",        "voltage": 3.3, "protocols": ["UART_RX"] },
      "GPIO17": { "type": "IO",        "voltage": 3.3, "protocols": ["UART_TX"] },
      "GPIO18": { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_SCK"] },
      "GPIO19": { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_MISO"] },
      "GPIO21": { "type": "IO",        "voltage": 3.3, "protocols": ["I2C_SDA"] },
      "GPIO22": { "type": "IO",        "voltage": 3.3, "protocols": ["I2C_SCL"] },
      "GPIO23": { "type": "IO",        "voltage": 3.3, "protocols": ["SPI_MOSI"] },
      "GPIO25": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH8", "DAC1"] },
      "GPIO26": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH9", "DAC2"] },
      "GPIO27": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC2_CH7", "TOUCH7"] },
      "GPIO32": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH4", "TOUCH9"] },
      "GPIO33": { "type": "IO",        "voltage": 3.3, "protocols": ["ADC1_CH5", "TOUCH8"] },
      "GPIO34": { "type": "INPUT",     "voltage": 3.3, "protocols": ["ADC1_CH6"],                        "notes": "Input only — no internal pull-up/down" },
      "GPIO35": { "type": "INPUT",     "voltage": 3.3, "protocols": ["ADC1_CH7"],                        "notes": "Input only — no internal pull-up/down" },
      "GPIO36": { "type": "INPUT",     "voltage": 3.3, "protocols": ["ADC1_CH0"],                        "notes": "Input only (VP)" },
      "GPIO39": { "type": "INPUT",     "voltage": 3.3, "protocols": ["ADC1_CH3"],                        "notes": "Input only (VN)" },
      "EN":     { "type": "INPUT",     "voltage": 3.3, "protocols": [],                                  "notes": "Chip enable — active HIGH" },
      "3V3":    { "type": "POWER_OUT", "voltage": 3.3, "protocols": [] },
      "5V":     { "type": "POWER_IN",  "voltage": 5.0, "protocols": [] },
      "VIN":    { "type": "POWER_IN",  "voltage": 5.0, "protocols": [] },
      "GND":    { "type": "GROUND",    "voltage": 0,   "protocols": [] }
    }
  },

